{
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ruff *)",
      "Bash(pytest *)",
      "Bash(tree *)",
      "Bash(python -m pytest:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(tee:*)",
      "Bash(yarn test:*)",
      "Bash(npx tsc:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(source opt/python/bin/activate)"
    ]
  },
  "teammateMode": "tmux",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
